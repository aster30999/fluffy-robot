# Solana Devnet Swap Test Configuration

# Optional: Your Solana private key (base58 encoded)
# If not provided, a new wallet will be generated
SOLANA_PRIVATE_KEY=your_private_key_here

# Optional: Custom RPC URL (defaults to Solana Devnet)
# SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional: Jupiter API key (if you have one)
# JUPITER_API_KEY=your_jupiter_api_key