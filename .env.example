# Solana Trading Bot - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# SOLANA CONFIGURATION
# ============================================================================
# RPC endpoint URL
SOLANA_RPC_URL=https://api.devnet.solana.com

# Network to use (devnet, testnet, mainnet-beta)
NETWORK=devnet

# Wallet private key (base58 encoded, 64 characters)
# Generate with: solana-keygen new --out-file wallet-key.json
# Then extract private key and encode to base58
WALLET_PRIVATE_KEY=

# Optional: Path to keypair file (alternative to WALLET_PRIVATE_KEY)
WALLET_KEYPAIR_PATH=

# ============================================================================
# JUPITER API CONFIGURATION
# ============================================================================
# Jupiter API key for higher rate limits (optional)
# Get from: https://developers.jup.ag/portal
JUPITER_API_KEY=

# Jupiter API base URL
JUPITER_API_URL=https://quote-api.jup.ag

# ============================================================================
# TRADING CONFIGURATION
# ============================================================================
# Trading interval in seconds (default: 60 = 1 minute)
TRADING_INTERVAL=60

# Default amount to swap (in SOL)
DEFAULT_SWAP_AMOUNT=0.01

# Maximum portfolio risk per trade (0.01 = 1%)
MAX_PORTFOLIO_RISK=0.01

# Slippage tolerance (0.01 = 1%)
SLIPPAGE_TOLERANCE=0.01

# ============================================================================
# TOKEN PAIRS
# ============================================================================
# Comma-separated list of token pairs to trade
# Format: SOL-USDC,SOL-USDT
TRADING_PAIRS=SOL-USDC

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log format (json, text)
LOG_FORMAT=text

# ============================================================================
# RISK MANAGEMENT
# ============================================================================
# Stop loss percentage (0.05 = 5%)
STOP_LOSS_PERCENTAGE=0.05

# Take profit percentage (0.10 = 10%)
TAKE_PROFIT_PERCENTAGE=0.10

# Maximum open trades
MAX_OPEN_TRADES=5

# ============================================================================
# INDICATOR CONFIGURATION
# ============================================================================
# These can also be configured via YAML files in config/indicators/
# Format: indicator_name:period:weight
# Example: RSI:14:1.0,MACD:12,26,9:1.0
INDICATORS=RSI:14:1.0,MACD:12,26,9:1.0

# ============================================================================
# DATABASE CONFIGURATION (Optional)
# ============================================================================
# For trade history and analytics
# DB_TYPE=sqlite (other: postgres)
DB_TYPE=sqlite
DB_PATH=./data/trading_bot.db

# ============================================================================
# MONITORING (Optional)
# ============================================================================
# Prometheus metrics endpoint (if enabled)
METRICS_ENABLED=false
METRICS_PORT=9090